{
  "manifest_version": 3,
  "name": "RecruitIngest",
  "version": "1.0",
  "description": "The official browser extension for RecruitIngest.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "RecruitIngest"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/styles.css"],
      "js": [
        "content/ui_core.js",
        "content/context_jobs.js",
        "content/context_profiles.js",
        "content/context_network.js",
        "content/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
